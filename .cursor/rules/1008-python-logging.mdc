## Requirements

### Logging Configuration
- Implement structured logging:
  ```python
  # Good: Structured logging configuration
  from typing import Any, Dict, List, Optional, Union
  import logging
  import logging.handlers
  import json
  import sys
  from datetime import datetime
  from pathlib import Path
  from dataclasses import dataclass, asdict
  import structlog
  from pythonjsonlogger import jsonlogger
  import traceback
  import threading
  import queue
  import time

  @dataclass
  class LogConfig:
      """Logging configuration."""
      level: str = "INFO"
      format: str = "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
      date_format: str = "%Y-%m-%d %H:%M:%S"
      file_path: Optional[Path] = None
      max_size: int = 10 * 1024 * 1024  # 10MB
      backup_count: int = 5
      json_format: bool = True
      console_output: bool = True
      syslog_host: Optional[str] = None
      syslog_port: int = 514
      log_retention_days: int = 30

  class JsonFormatter(jsonlogger.JsonFormatter):
      """JSON formatter for structured logging."""
      def add_fields(
          self,
          log_record: Dict[str, Any],
          record: logging.LogRecord,
          message_dict: Dict[str, Any]
      ) -> None:
          """Add fields to log record."""
          super().add_fields(log_record, record, message_dict)
          log_record['timestamp'] = datetime.utcnow().isoformat()
          log_record['level'] = record.levelname
          log_record['logger'] = record.name
          log_record['thread'] = record.thread
          log_record['thread_name'] = record.threadName
          log_record['process'] = record.process
          log_record['process_name'] = record.processName
          log_record['file'] = record.pathname
          log_record['line'] = record.lineno
          log_record['function'] = record.funcName
          log_record['module'] = record.module

  class LogManager:
      """Logging manager with structured logging."""
      def __init__(self, config: LogConfig):
          self.config = config
          self._logger: Optional[structlog.BoundLogger] = None
          self._setup_logging()

      def _setup_logging(self) -> None:
          """Setup logging configuration."""
          # Configure root logger
          root_logger = logging.getLogger()
          root_logger.setLevel(getattr(logging, self.config.level))

          # Create handlers
          handlers: List[logging.Handler] = []

          # File handler
          if self.config.file_path:
              file_handler = logging.handlers.RotatingFileHandler(
                  self.config.file_path,
                  maxBytes=self.config.max_size,
                  backupCount=self.config.backup_count
              )
              handlers.append(file_handler)

          # Console handler
          if self.config.console_output:
              console_handler = logging.StreamHandler(sys.stdout)
              handlers.append(console_handler)

          # Syslog handler
          if self.config.syslog_host:
              syslog_handler = logging.handlers.SysLogHandler(
                  address=(self.config.syslog_host, self.config.syslog_port)
              )
              handlers.append(syslog_handler)

          # Configure handlers
          for handler in handlers:
              if self.config.json_format:
                  handler.setFormatter(JsonFormatter())
              else:
                  handler.setFormatter(
                      logging.Formatter(
                          self.config.format,
                          self.config.date_format
                      )
                  )
              root_logger.addHandler(handler)

          # Configure structlog
          structlog.configure(
              processors=[
                  structlog.processors.TimeStamper(fmt="iso"),
                  structlog.processors.JSONRenderer()
              ],
              context_class=dict,
              logger_factory=structlog.PrintLoggerFactory(),
              wrapper_class=structlog.BoundLogger
          )
          self._logger = structlog.get_logger()

      def get_logger(self, name: str) -> structlog.BoundLogger:
          """Get logger instance."""
          return self._logger.bind(logger_name=name)

      def cleanup_old_logs(self) -> None:
          """Clean up old log files."""
          if not self.config.file_path:
              return

          log_dir = self.config.file_path.parent
          cutoff = time.time() - (self.config.log_retention_days * 86400)

          for log_file in log_dir.glob(f"{self.config.file_path.stem}.*"):
              if log_file.stat().st_mtime < cutoff:
                  log_file.unlink()

  class LogContext:
      """Context manager for logging."""
      def __init__(
          self,
          logger: structlog.BoundLogger,
          context: Dict[str, Any]
      ):
          self.logger = logger
          self.context = context
          self._previous_context: Optional[Dict[str, Any]] = None

      def __enter__(self) -> structlog.BoundLogger:
          """Enter logging context."""
          self._previous_context = self.logger._context.copy()
          return self.logger.bind(**self.context)

      def __exit__(
          self,
          exc_type: Optional[Type[Exception]],
          exc_val: Optional[Exception],
          exc_tb: Optional[TracebackType]
      ) -> None:
          """Exit logging context."""
          self.logger._context.clear()
          self.logger._context.update(self._previous_context)

  class LogAggregator:
      """Log aggregation manager."""
      def __init__(
          self,
          batch_size: int = 100,
          flush_interval: float = 5.0
      ):
          self.batch_size = batch_size
          self.flush_interval = flush_interval
          self._queue: queue.Queue = queue.Queue()
          self._buffer: List[Dict[str, Any]] = []
          self._last_flush = time.time()
          self._stop_event = threading.Event()
          self._worker_thread = threading.Thread(
              target=self._process_logs,
              daemon=True
          )
          self._worker_thread.start()

      def add_log(self, log_entry: Dict[str, Any]) -> None:
          """Add log entry to queue."""
          self._queue.put(log_entry)

      def _process_logs(self) -> None:
          """Process logs in background."""
          while not self._stop_event.is_set():
              try:
                  # Get log entry with timeout
                  log_entry = self._queue.get(timeout=1.0)
                  self._buffer.append(log_entry)

                  # Check if buffer should be flushed
                  current_time = time.time()
                  if (
                      len(self._buffer) >= self.batch_size
                      or current_time - self._last_flush >= self.flush_interval
                  ):
                      self._flush_buffer()

              except queue.Empty:
                  # Check if buffer should be flushed
                  if time.time() - self._last_flush >= self.flush_interval:
                      self._flush_buffer()

      def _flush_buffer(self) -> None:
          """Flush log buffer."""
          if not self._buffer:
              return

          try:
              # Send logs to aggregation service
              self._send_logs(self._buffer)
              self._last_flush = time.time()
          except Exception as e:
              logging.error(f"Error flushing logs: {e}")
          finally:
              self._buffer.clear()

      def _send_logs(self, logs: List[Dict[str, Any]]) -> None:
          """Send logs to aggregation service."""
          # Implement log sending logic here
          # Example: Send to ELK stack, CloudWatch, etc.
          pass

      def stop(self) -> None:
          """Stop log aggregator."""
          self._stop_event.set()
          self._worker_thread.join()
          self._flush_buffer()
  ```

### Log Levels
- Implement appropriate log levels:
  ```python
  # Good: Log level implementation
  from typing import Any, Dict, Optional
  import logging
  import structlog
  from dataclasses import dataclass
  from datetime import datetime
  import time
  import functools
  import inspect

  @dataclass
  class LogLevel:
      """Log level configuration."""
      DEBUG: int = logging.DEBUG
      INFO: int = logging.INFO
      WARNING: int = logging.WARNING
      ERROR: int = logging.ERROR
      CRITICAL: int = logging.CRITICAL

  class LogLevelManager:
      """Log level management."""
      def __init__(self, logger: structlog.BoundLogger):
          self.logger = logger
          self._level_thresholds: Dict[str, int] = {
              'DEBUG': LogLevel.DEBUG,
              'INFO': LogLevel.INFO,
              'WARNING': LogLevel.WARNING,
              'ERROR': LogLevel.ERROR,
              'CRITICAL': LogLevel.CRITICAL
          }

      def set_level(self, level: str) -> None:
          """Set log level."""
          if level not in self._level_thresholds:
              raise ValueError(f"Invalid log level: {level}")
          logging.getLogger().setLevel(self._level_thresholds[level])

      def get_level(self) -> str:
          """Get current log level."""
          level = logging.getLogger().getEffectiveLevel()
          for name, value in self._level_thresholds.items():
              if level == value:
                  return name
          return "UNKNOWN"

  def log_execution(
      level: str = "INFO",
      include_args: bool = True,
      include_result: bool = True
  ):
      """Decorator for logging function execution."""
      def decorator(func):
          @functools.wraps(func)
          def wrapper(*args, **kwargs):
              logger = structlog.get_logger(func.__module__)
              start_time = time.time()

              # Log function entry
              log_data = {
                  'function': func.__name__,
                  'event': 'function_start'
              }
              if include_args:
                log_data['args'] = args
                log_data['kwargs'] = kwargs
              getattr(logger, level.lower())(**log_data)

              try:
                  result = func(*args, **kwargs)
                  duration = time.time() - start_time

                  # Log function exit
                  log_data = {
                      'function': func.__name__,
                      'event': 'function_end',
                      'duration': duration
                  }
                  if include_result:
                    log_data['result'] = result
                  getattr(logger, level.lower())(**log_data)

                  return result

              except Exception as e:
                  duration = time.time() - start_time

                  # Log function error
                  log_data = {
                      'function': func.__name__,
                      'event': 'function_error',
                      'duration': duration,
                      'error': str(e),
                      'traceback': traceback.format_exc()
                  }
                  logger.error(**log_data)
                  raise

          return wrapper
      return decorator

  class LogMetrics:
      """Log metrics collection."""
      def __init__(self):
          self._metrics: Dict[str, List[float]] = {}
          self._counts: Dict[str, int] = {}
          self._start_times: Dict[str, float] = {}

      def start_operation(self, operation: str) -> None:
          """Start timing operation."""
          self._start_times[operation] = time.time()

      def end_operation(self, operation: str) -> None:
          """End timing operation."""
          if operation not in self._start_times:
              return

          duration = time.time() - self._start_times[operation]
          if operation not in self._metrics:
              self._metrics[operation] = []
          self._metrics[operation].append(duration)
          self._counts[operation] = self._counts.get(operation, 0) + 1

      def get_metrics(self) -> Dict[str, Dict[str, float]]:
          """Get operation metrics."""
          result: Dict[str, Dict[str, float]] = {}
          for operation, durations in self._metrics.items():
              result[operation] = {
                  'count': self._counts[operation],
                  'avg_duration': sum(durations) / len(durations),
                  'min_duration': min(durations),
                  'max_duration': max(durations),
                  'total_duration': sum(durations)
              }
          return result
  ```

### Performance Logging
- Implement performance monitoring:
  ```python
  # Good: Performance logging implementation
  from typing import Any, Callable, Dict, List, Optional, TypeVar
  import time
  import psutil
  import logging
  import structlog
  from dataclasses import dataclass
  from datetime import datetime
  import threading
  import queue
  import json

  T = TypeVar('T')

  @dataclass
  class PerformanceMetrics:
      """Performance metrics."""
      cpu_percent: float
      memory_percent: float
      disk_io: Dict[str, float]
      network_io: Dict[str, float]
      thread_count: int
      timestamp: datetime

  class PerformanceMonitor:
      """Performance monitoring system."""
      def __init__(
          self,
          logger: structlog.BoundLogger,
          interval: float = 60.0
      ):
          self.logger = logger
          self.interval = interval
          self._stop_event = threading.Event()
          self._monitor_thread = threading.Thread(
              target=self._monitor_performance,
              daemon=True
          )
          self._monitor_thread.start()

      def _monitor_performance(self) -> None:
          """Monitor system performance."""
          while not self._stop_event.is_set():
              try:
                  metrics = self._collect_metrics()
                  self._log_metrics(metrics)
                  time.sleep(self.interval)
              except Exception as e:
                  self.logger.error(
                      "Error monitoring performance",
                      error=str(e)
                  )

      def _collect_metrics(self) -> PerformanceMetrics:
          """Collect system metrics."""
          process = psutil.Process()
          return PerformanceMetrics(
              cpu_percent=process.cpu_percent(),
              memory_percent=process.memory_percent(),
              disk_io={
                  'read_bytes': process.io_counters().read_bytes,
                  'write_bytes': process.io_counters().write_bytes
              },
              network_io={
                  'bytes_sent': process.io_counters().write_bytes,
                  'bytes_recv': process.io_counters().read_bytes
              },
              thread_count=process.num_threads(),
              timestamp=datetime.utcnow()
          )

      def _log_metrics(self, metrics: PerformanceMetrics) -> None:
          """Log performance metrics."""
          self.logger.info(
              "Performance metrics",
              **asdict(metrics)
          )

      def stop(self) -> None:
          """Stop performance monitoring."""
          self._stop_event.set()
          self._monitor_thread.join()

  def log_performance(
      logger: structlog.BoundLogger,
      operation: str
  ) -> Callable:
      """Decorator for logging function performance."""
      def decorator(func: Callable[..., T]) -> Callable[..., T]:
          @functools.wraps(func)
          def wrapper(*args: Any, **kwargs: Any) -> T:
              start_time = time.time()
              start_metrics = PerformanceMonitor._collect_metrics()

              try:
                  result = func(*args, **kwargs)
                  return result
              finally:
                  end_time = time.time()
                  end_metrics = PerformanceMonitor._collect_metrics()
                  duration = end_time - start_time

                  # Calculate metrics
                  metrics = {
                      'operation': operation,
                      'duration': duration,
                      'cpu_delta': end_metrics.cpu_percent - start_metrics.cpu_percent,
                      'memory_delta': end_metrics.memory_percent - start_metrics.memory_percent,
                      'disk_read_delta': (
                          end_metrics.disk_io['read_bytes'] -
                          start_metrics.disk_io['read_bytes']
                      ),
                      'disk_write_delta': (
                          end_metrics.disk_io['write_bytes'] -
                          start_metrics.disk_io['write_bytes']
                      ),
                      'network_sent_delta': (
                          end_metrics.network_io['bytes_sent'] -
                          start_metrics.network_io['bytes_sent']
                      ),
                      'network_recv_delta': (
                          end_metrics.network_io['bytes_recv'] -
                          start_metrics.network_io['bytes_recv']
                      )
                  }

                  logger.info(
                      "Performance metrics",
                      **metrics
                  )

          return wrapper
      return decorator
  ```

### Contextual Logging
- Implement contextual logging:
  ```python
  # Good: Contextual logging implementation
  from typing import Any, Dict, Optional, Union
  import logging
  import structlog
  from dataclasses import dataclass
  from datetime import datetime
  import threading
  import uuid
  import json
  from contextvars import ContextVar
  from functools import wraps

  @dataclass
  class LogContext:
      """Log context data."""
      request_id: str
      user_id: Optional[str]
      correlation_id: Optional[str]
      timestamp: datetime
      extra: Dict[str, Any]

  class ContextualLogger:
      """Contextual logging system."""
      def __init__(self):
          self._context_var = ContextVar('log_context', default=None)
          self._logger = structlog.get_logger()

      def get_context(self) -> Optional[LogContext]:
          """Get current log context."""
          return self._context_var.get()

      def set_context(
          self,
          request_id: Optional[str] = None,
          user_id: Optional[str] = None,
          correlation_id: Optional[str] = None,
          **extra: Any
      ) -> None:
          """Set log context."""
          context = LogContext(
              request_id=request_id or str(uuid.uuid4()),
              user_id=user_id,
              correlation_id=correlation_id,
              timestamp=datetime.utcnow(),
              extra=extra
          )
          self._context_var.set(context)

      def clear_context(self) -> None:
          """Clear log context."""
          self._context_var.set(None)

      def get_logger(self) -> structlog.BoundLogger:
          """Get logger with context."""
          context = self.get_context()
          if context is None:
              return self._logger

          return self._logger.bind(
              request_id=context.request_id,
              user_id=context.user_id,
              correlation_id=context.correlation_id,
              **context.extra
          )

  def with_log_context(
      request_id: Optional[str] = None,
      user_id: Optional[str] = None,
      correlation_id: Optional[str] = None,
      **extra: Any
  ):
      """Decorator for adding log context."""
      def decorator(func):
          @wraps(func)
          def wrapper(*args, **kwargs):
              logger = ContextualLogger()
              logger.set_context(
                  request_id=request_id,
                  user_id=user_id,
                  correlation_id=correlation_id,
                  **extra
              )
              try:
                  return func(*args, **kwargs)
              finally:
                  logger.clear_context()
          return wrapper
      return decorator

  class RequestLogger:
      """Request logging system."""
      def __init__(self, logger: ContextualLogger):
          self.logger = logger
          self._start_times: Dict[str, float] = {}

      def start_request(
          self,
          request_id: str,
          method: str,
          path: str,
          **extra: Any
      ) -> None:
          """Log request start."""
          self._start_times[request_id] = time.time()
          self.logger.set_context(
              request_id=request_id,
              **extra
          )
          self.logger.get_logger().info(
              "Request started",
              method=method,
              path=path
          )

      def end_request(
          self,
          request_id: str,
          status_code: int,
          **extra: Any
      ) -> None:
          """Log request end."""
          if request_id not in self._start_times:
              return

          duration = time.time() - self._start_times[request_id]
          self.logger.get_logger().info(
              "Request completed",
              status_code=status_code,
              duration=duration,
              **extra
          )
          del self._start_times[request_id]
  ```

