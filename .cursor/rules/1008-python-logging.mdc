        context = self.get_context()
        if context is None:
            return self._logger

        return self._logger.bind(**context)

# Application implementation
class Application:
    """Application with comprehensive logging."""
    def __init__(
        self,
        log_manager: LogManager,
        contextual_logger: ContextualLogger
    ):
        self.log_manager = log_manager
        self.contextual_logger = contextual_logger
        self.logger = log_manager.get_logger(__name__)
        self.performance_monitor = PerformanceMonitor(self.logger)

    async def process_request(
        self,
        request_id: str,
        user_id: str,
        data: Dict[str, Any]
    ) -> Dict[str, Any]:
        """Process request with logging."""
        # Set request context
        self.contextual_logger.set_context(
            request_id=request_id,
            user_id=user_id
        )

        try:
            # Log request start
            self.logger.info(
                "Processing request",
                data=data
            )

            # Process request
            result = await self._process_data(data)

            # Log request completion
            self.logger.info(
                "Request completed",
                result=result
            )

            return result

        except Exception as e:
            # Log error
            self.logger.error(
                "Request failed",
                error=str(e),
                traceback=traceback.format_exc()
            )
            raise

        finally:
            # Clear context
            self.contextual_logger.clear_context()

    async def _process_data(
        self,
        data: Dict[str, Any]
    ) -> Dict[str, Any]:
        """Process data with performance logging."""
        start_time = time.time()
        start_metrics = self.performance_monitor._collect_metrics()

        try:
            # Process data
            result = {
                'processed': True,
                'timestamp': datetime.utcnow().isoformat()
            }

            # Log performance metrics
            end_time = time.time()
            end_metrics = self.performance_monitor._collect_metrics()
            duration = end_time - start_time

            metrics = {
                'operation': 'process_data',
                'duration': duration,
                'cpu_delta': end_metrics['cpu_percent'] - start_metrics['cpu_percent'],
                'memory_delta': end_metrics['memory_percent'] - start_metrics['memory_percent'],
                'disk_read_delta': (
                    end_metrics['disk_io']['read_bytes'] -
                    start_metrics['disk_io']['read_bytes']
                ),
                'disk_write_delta': (
                    end_metrics['disk_io']['write_bytes'] -
                    start_metrics['disk_io']['write_bytes']
                )
            }

            self.logger.info(
                "Performance metrics",
                **metrics
            )

            return result

        except Exception as e:
            self.logger.error(
                "Data processing failed",
                error=str(e)
            )
            raise

# Usage example
async def main():
    """Example usage."""
    # Initialize logging
    config = LogConfig(
        file_path=Path("app.log"),
        json_format=True
    )
    log_manager = LogManager(config)
    contextual_logger = ContextualLogger()

    # Create application
    app = Application(log_manager, contextual_logger)

    try:
        # Process request
        result = await app.process_request(
            request_id=str(uuid.uuid4()),
            user_id="user123",
            data={"key": "value"}
        )
        print(f"Result: {result}")

    finally:
        # Cleanup
        app.performance_monitor.stop()

if __name__ == "__main__":
    asyncio.run(main())
