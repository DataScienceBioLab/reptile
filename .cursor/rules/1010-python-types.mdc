## Examples

<example>
# Good: Complete type-safe implementation
```python
"""Type-safe data processing module."""

from typing import (
    Any, Callable, Dict, Generic, List, Optional,
    Protocol, TypeAlias, TypeVar, Union, runtime_checkable,
    TypeGuard, cast, Awaitable, Coroutine
)
from dataclasses import dataclass
from datetime import datetime
from enum import Enum

T = TypeVar('T')
R = TypeVar('R')
E = TypeVar('E', bound=Exception)

class ProcessingStatus(str, Enum):
    """Processing status enumeration."""
    PENDING = "pending"
    PROCESSING = "processing"
    COMPLETED = "completed"
    FAILED = "failed"

@runtime_checkable
class DataProcessor(Protocol):
    """Protocol for data processors."""
    def process(self, data: Any) -> Any: ...

@dataclass
class ProcessingResult(Generic[T, E]):
    """Generic processing result."""
    value: Optional[T]
    status: ProcessingStatus
    error: Optional[E]
    timestamp: datetime
    metadata: Dict[str, Any]

    def is_success(self) -> bool:
        """Check if processing was successful."""
        return self.status == ProcessingStatus.COMPLETED

    def map(self, func: Callable[[T], R]) -> 'ProcessingResult[R, E]':
        """Transform result value."""
        if self.is_success():
            return ProcessingResult(
                value=func(self.value),
                status=self.status,
                error=None,
                timestamp=self.timestamp,
                metadata=self.metadata
            )
        return ProcessingResult(
            value=None,
            status=self.status,
            error=self.error,
            timestamp=self.timestamp,
            metadata=self.metadata
        )

class DataTransformer:
    """Type-safe data transformer."""

    def __init__(
        self,
        processor: DataProcessor,
        validator: Optional[Callable[[Any], bool]] = None
    ):
        """Initialize transformer."""
        self.processor = processor
        self.validator = validator

    def transform(
        self,
        data: Any
    ) -> ProcessingResult[Any, Exception]:
        """Transform data with type safety."""
        try:
            if self.validator and not self.validator(data):
                raise ValueError("Invalid input data")

            result = self.processor.process(data)
            return ProcessingResult(
                value=result,
                status=ProcessingStatus.COMPLETED,
                error=None,
                timestamp=datetime.utcnow(),
                metadata={"processed": True}
            )
        except Exception as e:
            return ProcessingResult(
                value=None,
                status=ProcessingStatus.FAILED,
                error=e,
                timestamp=datetime.utcnow(),
                metadata={"processed": False}
            )

    def batch_transform(
        self,
        items: List[Any]
    ) -> List[ProcessingResult[Any, Exception]]:
        """Transform multiple items."""
        return [self.transform(item) for item in items]

class UserProcessor(DataProcessor):
    """User data processor."""

    def process(self, data: Dict[str, Any]) -> Dict[str, Any]:
        """Process user data."""
        return {
            "id": int(data["id"]),
            "name": str(data["name"]),
            "email": str(data["email"])
        }

def validate_user(data: Any) -> TypeGuard[Dict[str, Any]]:
    """Type guard for user data validation."""
    if not isinstance(data, dict):
        return False
    required = {"id", "name", "email"}
    return all(key in data for key in required)

# Usage example
def process_user_data() -> None:
    """Process user data with type safety."""
    processor = UserProcessor()
    transformer = DataTransformer(processor, validate_user)

    user_data = {
        "id": "123",
        "name": "John Doe",
        "email": "john@example.com"
    }

    result = transformer.transform(user_data)
    if result.is_success():
        print(f"Processed user: {result.value}")
    else:
        print(f"Processing failed: {result.error}")
```
</example>

