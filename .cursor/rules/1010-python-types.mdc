## Requirements

### Type Checker Configuration
- Configure mypy for strict type checking:
  ```ini
  # mypy.ini
  [mypy]
  python_version = 3.10
  warn_return_any = True
  warn_unused_configs = True
  disallow_untyped_defs = True
  disallow_incomplete_defs = True
  check_untyped_defs = True
  disallow_untyped_decorators = True
  no_implicit_optional = True
  warn_redundant_casts = True
  warn_unused_ignores = True
  warn_no_return = True
  warn_unreachable = True
  strict_optional = True
  ```

### Type Hint Implementation
- Use comprehensive type hints:
  ```python
  # Good: Well-typed function with complex types
  from typing import (
      Any, Dict, List, Optional, Protocol, TypeVar,
      Union, runtime_checkable, TypeAlias, TypedDict,
      Callable, Awaitable, Coroutine, TypeGuard, cast
  )
  from dataclasses import dataclass
  from datetime import datetime
  from enum import Enum

  T = TypeVar('T', bound='Comparable')
  R = TypeVar('R')

  class UserRole(str, Enum):
      """User role enumeration."""
      ADMIN = "admin"
      USER = "user"
      GUEST = "guest"

  class Comparable(Protocol):
      """Protocol for comparable objects."""
      def __lt__(self, other: Any) -> bool: ...

  @dataclass
  class User:
      """User data with type hints."""
      id: int
      name: str
      email: str
      created_at: datetime
      preferences: Dict[str, Any]
      role: UserRole
      is_active: bool = True

  UserList: TypeAlias = List[User]
  UserDict: TypeAlias = Dict[int, User]
  UserCallback: TypeAlias = Callable[[User], bool]

  def process_users(
      users: UserList,
      filter_func: Optional[UserCallback] = None,
      include_inactive: bool = False
  ) -> UserDict:
      """Process users with type safety."""
      result: UserDict = {}
      for user in users:
          if not include_inactive and not user.is_active:
              continue
          if filter_func is None or filter_func(user):
              result[user.id] = user
      return result
  ```

### Type Narrowing
- Implement proper type narrowing:
  ```python
  # Good: Type narrowing with type guards
  def is_valid_user(data: Any) -> TypeGuard[Dict[str, Any]]:
      """Type guard for user data validation."""
      if not isinstance(data, dict):
          return False
      required = {"id", "name", "email"}
      return all(key in data for key in required)

  def process_user_data(data: Any) -> Optional[User]:
      """Process user data with type narrowing."""
      if is_valid_user(data):
          # Type checker knows data is Dict[str, Any]
          return User(
              id=int(data["id"]),
              name=str(data["name"]),
              email=str(data["email"]),
              created_at=datetime.utcnow(),
              preferences={},
              role=UserRole.USER
          )
      return None
  ```

### Protocol Definitions
- Use protocols for structural typing:
  ```python
  # Good: Protocol usage with async support
  @runtime_checkable
  class AsyncDataSource(Protocol):
      """Protocol for async data sources."""
      async def read(self) -> bytes: ...
      async def write(self, data: bytes) -> None: ...
      async def close(self) -> None: ...

  class AsyncFileDataSource:
      """Async file-based data source implementation."""
      def __init__(self, filepath: str):
          self.filepath = filepath
          self._file: Optional[IO[bytes]] = None

      async def read(self) -> bytes:
          async with aiofiles.open(self.filepath, 'rb') as f:
              return await f.read()

      async def write(self, data: bytes) -> None:
          async with aiofiles.open(self.filepath, 'wb') as f:
              await f.write(data)

      async def close(self) -> None:
          if self._file:
              self._file.close()
              self._file = None

  async def process_data(source: AsyncDataSource) -> None:
      """Process data from any async source."""
      try:
          data = await source.read()
          # Process data
      finally:
          await source.close()
  ```

### Generic Type Usage
- Implement generic types properly:
  ```python
  # Good: Advanced generic type implementation
  T = TypeVar('T')
  R = TypeVar('R')
  E = TypeVar('E', bound=Exception)

  class Result(Generic[T, E]):
      """Generic result type with error handling."""
      def __init__(
          self,
          value: Optional[T] = None,
          error: Optional[E] = None
      ):
          if value is not None and error is not None:
              raise ValueError("Cannot have both value and error")
          self.value = value
          self.error = error

      def is_success(self) -> bool:
          """Check if result is successful."""
          return self.error is None

      def map(self, func: Callable[[T], R]) -> 'Result[R, E]':
          """Transform result value."""
          if self.is_success():
              return Result(value=func(self.value))
          return Result(error=self.error)

      def flat_map(
          self,
          func: Callable[[T], 'Result[R, E]']
      ) -> 'Result[R, E]':
          """Transform result with nested result."""
          if self.is_success():
              return func(self.value)
          return Result(error=self.error)

      def recover(
          self,
          func: Callable[[E], T]
      ) -> 'Result[T, E]':
          """Recover from error."""
          if not self.is_success():
              return Result(value=func(self.error))
          return self

  class OptionalResult(Result[Optional[T], E]):
      """Optional result type."""
      def unwrap(self) -> T:
          """Unwrap optional value."""
          if not self.is_success():
              raise self.error
          if self.value is None:
              raise ValueError("Cannot unwrap None")
          return self.value
  ```

### TypedDict Usage
- Use TypedDict for dictionary types:
  ```python
  # Good: Advanced TypedDict usage
  class UserData(TypedDict, total=True):
      """Typed dictionary for user data."""
      id: int
      name: str
      email: str
      preferences: Dict[str, Any]
      role: UserRole
      created_at: datetime

  class PartialUserData(TypedDict, total=False):
      """Optional user data fields."""
      id: int
      name: str
      email: str
      preferences: Dict[str, Any]
      role: UserRole
      created_at: datetime

  class UserResponse(TypedDict, total=True):
      """API response type."""
      success: bool
      data: Optional[UserData]
      error: Optional[str]

  def create_user(data: UserData) -> User:
      """Create user from typed data."""
      return User(**data)

  def update_user(user: User, data: PartialUserData) -> User:
      """Update user with partial data."""
      return User(**{**user.__dict__, **data})

  def format_response(
      success: bool,
      data: Optional[UserData] = None,
      error: Optional[str] = None
  ) -> UserResponse:
      """Format API response."""
      return UserResponse(
          success=success,
          data=data,
          error=error
      )
  ```

### Type Inference
- Leverage type inference appropriately:
  ```python
  # Good: Type inference usage
  def process_items(items: List[T]) -> List[T]:
      """Process items with type inference."""
      return [item for item in items if item is not None]

  def create_user_dict(users: List[User]) -> Dict[int, User]:
      """Create user dictionary with type inference."""
      return {user.id: user for user in users}

  def filter_active_users(users: List[User]) -> List[User]:
      """Filter active users with type inference."""
      return [user for user in users if user.is_active]
  ```

