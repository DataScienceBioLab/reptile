## Examples

<example>
# Good: Complete documentation structure
```python
"""Machine learning utilities for data processing and model training.

This module provides a comprehensive set of tools for:
1. Data preprocessing and cleaning
2. Feature engineering
3. Model training and evaluation
4. Performance metrics calculation

Example:
    >>> from ml_utils import DataProcessor, train_model
    >>> processor = DataProcessor()
    >>> clean_data = processor.clean(raw_data)
    >>> model = RandomForestClassifier()
    >>> metrics = train_model(model, clean_data, target)
"""

from typing import Any, Dict, Optional
import numpy as np
import pandas as pd
from sklearn.base import BaseEstimator

class DataProcessor:
    """Process and transform data for machine learning tasks.

    This class provides methods for data preprocessing, cleaning,
    and feature engineering.

    Attributes:
        config: Processing configuration dictionary
        scaler: Optional data scaler instance

    Example:
        >>> processor = DataProcessor(config={'normalize': True})
        >>> clean_data = processor.process(raw_data)
    """

    def __init__(
        self,
        config: Optional[Dict[str, Any]] = None,
        scaler: Optional[BaseEstimator] = None,
    ) -> None:
        """Initialize the data processor.

        Args:
            config: Processing configuration
            scaler: Optional data scaler

        Example:
            >>> processor = DataProcessor(
            ...     config={'normalize': True},
            ...     scaler=StandardScaler()
            ... )
        """
        self.config = config or {}
        self.scaler = scaler

    def process(self, data: pd.DataFrame) -> pd.DataFrame:
        """Process input data according to configuration.

        Args:
            data: Input DataFrame to process

        Returns:
            Processed DataFrame

        Raises:
            ValueError: If input data is invalid

        Example:
            >>> df = pd.DataFrame({'col1': [1, 2, 3]})
            >>> processed = processor.process(df)
            >>> print(processed)
               col1
            0   0.0
            1   0.5
            2   1.0
        """
        if data.empty:
            raise ValueError("Input DataFrame cannot be empty")
        
        result = data.copy()
        if self.config.get('normalize') and self.scaler:
            result = pd.DataFrame(
                self.scaler.fit_transform(result),
                columns=result.columns
            )
        return result
```
</example>

