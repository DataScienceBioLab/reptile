import numpy as np
import pandas as pd
from typing import *

def process_data(data, cols, threshold=0.5):
    # Process the data
    result = data[cols].clip(lower=threshold)
    return result

class DataProcessor:
    def __init__(self, config):
        self.config = config

    def process(self, data, cols):
        # Process data
        return process_data(data, cols)
