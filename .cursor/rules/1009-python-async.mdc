          self.rate_limiter = RateLimiter(
              self.config.rate_limit,
              self.config.rate_limit_period
          )

      def _setup_request_validation(self) -> None:
          """Setup request validation."""
          self.allowed_origins = set(self.config.allowed_origins or [])

      async def secure_request(
          self,
          method: str,
          url: str,
          **kwargs: Any
      ) -> aiohttp.ClientResponse:
          """Make secure HTTP request."""
          if not self._validate_url(url):
              raise SecurityError("Invalid URL")

          if not await self.rate_limiter.acquire():
              raise RateLimitError("Rate limit exceeded")

          ssl_context = self.ssl_context if self.config.ssl_verify else None
          async with aiohttp.ClientSession() as session:
              async with session.request(
                  method,
                  url,
                  ssl=ssl_context,
                  **kwargs
              ) as response:
                  if not self._validate_response(response):
                      raise SecurityError("Invalid response")
                  return response

      def _validate_url(self, url: str) -> bool:
          """Validate URL security."""
          if not url.startswith(('http://', 'https://')):
              return False

          parsed = aiohttp.helpers.parse_url(url)
          if not parsed:
              return False

          if self.allowed_origins:
              return parsed.host in self.allowed_origins
          return True

      def _validate_response(self, response: aiohttp.ClientResponse) -> bool:
          """Validate response security."""
          if response.status >= 400:
              return False

          content_type = response.headers.get('Content-Type', '')
          if 'application/json' in content_type:
              try:
                  response.json()
                  return True
              except json.JSONDecodeError:
                  return False
          return True

      def encrypt_data(self, data: str) -> str:
          """Encrypt sensitive data."""
          return self.fernet.encrypt(data.encode()).decode()

      def decrypt_data(self, encrypted_data: str) -> str:
          """Decrypt sensitive data."""
          return self.fernet.decrypt(encrypted_data.encode()).decode()

      def generate_token(
          self,
          payload: Dict[str, Any],
          expires_in: int = 3600
      ) -> str:
          """Generate JWT token."""
          if not self.config.jwt_secret:
              raise SecurityError("JWT secret not configured")

          payload['exp'] = datetime.utcnow().timestamp() + expires_in
          return jwt.encode(
              payload,
              self.config.jwt_secret,
              algorithm='HS256'
          )

      def verify_token(self, token: str) -> Dict[str, Any]:
          """Verify JWT token."""
          if not self.config.jwt_secret:
              raise SecurityError("JWT secret not configured")

          try:
              return jwt.decode(
                  token,
                  self.config.jwt_secret,
                  algorithms=['HS256']
              )
          except jwt.ExpiredSignatureError:
              raise SecurityError("Token expired")
          except jwt.InvalidTokenError:
              raise SecurityError("Invalid token")

      def hash_password(
          self,
          password: str,
          salt: Optional[bytes] = None
      ) -> Tuple[str, bytes]:
          """Hash password with salt."""
          if salt is None:
              salt = os.urandom(16)

          kdf = PBKDF2HMAC(
              algorithm=hashes.SHA256(),
              length=32,
              salt=salt,
              iterations=100000
          )
          key = base64.urlsafe_b64encode(
              kdf.derive(password.encode())
          )
          return key.decode(), salt

      def verify_password(
          self,
          password: str,
          hashed: str,
          salt: bytes
      ) -> bool:
          """Verify password hash."""
          key, _ = self.hash_password(password, salt)
          return hmac.compare_digest(key, hashed)

  class RateLimiter:
