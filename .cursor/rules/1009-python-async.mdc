                  logging.error(f"Resource monitoring error: {e}")
                  await asyncio.sleep(5.0)

      async def _cleanup_resources(self) -> None:
          """Cleanup idle resources."""
          while not self._shutdown_event.is_set():
              try:
                  current_time = datetime.utcnow()
                  for resource_id, last_used in list(self._resource_usage.items()):
                      if (current_time - last_used).total_seconds() > self.config.idle_timeout:
                          await self.release_resource(resource_id)

                  await asyncio.sleep(self.config.cleanup_interval)
              except Exception as e:
                  logging.error(f"Resource cleanup error: {e}")
                  await asyncio.sleep(5.0)

      async def _handle_resource_exhaustion(self) -> None:
          """Handle resource exhaustion."""
          # Release idle resources
          await self._cleanup_resources()

          # Force garbage collection
          gc.collect()

          # Check if we need to terminate
          process = psutil.Process()
          if (process.memory_percent() > self.config.max_memory_percent * 1.5 or
              process.cpu_percent() > self.config.max_cpu_percent * 1.5):
