      enable_tracing: bool = True
      enable_metrics: bool = True
      enable_profiling: bool = False
      sampling_rate: float = 0.1
      max_samples: int = 1000
      retention_period: float = 3600.0  # 1 hour

  class AsyncPerformanceMonitor:
      """Async performance monitoring system."""
      def __init__(self, config: PerformanceMetrics):
          self.config = config
          self._setup_metrics()
          self._setup_tracing()
          self._setup_profiling()
          self._samples: Dict[str, List[float]] = {}
          self._last_cleanup = time.time()

      def _setup_metrics(self) -> None:
          """Setup Prometheus metrics."""
          if not self.config.enable_metrics:
              return

          # Task metrics
          self.task_duration = prom.Histogram(
              'async_task_duration_seconds',
              'Task execution duration',
              ['task_name']
          )
          self.task_count = prom.Counter(
              'async_task_total',
              'Total number of tasks',
              ['task_name']
          )
          self.task_errors = prom.Counter(
              'async_task_errors_total',
              'Total number of task errors',
              ['task_name']
          )

          # Resource metrics
          self.memory_usage = prom.Gauge(
              'async_memory_usage_bytes',
              'Memory usage'
          )
          self.cpu_usage = prom.Gauge(
              'async_cpu_usage_percent',
              'CPU usage percentage'
          )

          # Queue metrics
          self.queue_size = prom.Gauge(
              'async_queue_size',
              'Current queue size',
              ['queue_name']
          )

      def _setup_tracing(self) -> None:
          """Setup tracing."""
          if not self.config.enable_tracing:
              return

          self.trace_logger = logging.getLogger('async_tracing')
          self.trace_logger.setLevel(logging.DEBUG)

      def _setup_profiling(self) -> None:
          """Setup profiling."""
          if not self.config.enable_profiling:
              return

          self.profiler = cProfile.Profile()

      async def monitor_task(
          self,
          task_name: str,
          coro: Any,
          *args: Any,
          **kwargs: Any
      ) -> Any:
          """Monitor task execution."""
          start_time = time.time()
          self.task_count.labels(task_name=task_name).inc()

          try:
              result = await coro(*args, **kwargs)
              duration = time.time() - start_time
              self.task_duration.labels(task_name=task_name).observe(duration)
              self._record_sample(task_name, duration)
              return result
          except Exception as e:
              self.task_errors.labels(task_name=task_name).inc()
              raise

      def _record_sample(self, task_name: str, duration: float) -> None:
          """Record performance sample."""
          if task_name not in self._samples:
              self._samples[task_name] = []
          self._samples[task_name].append(duration)

          # Cleanup old samples
          if time.time() - self._last_cleanup > self.config.retention_period:
              self._cleanup_samples()

      def _cleanup_samples(self) -> None:
          """Cleanup old samples."""
          current_time = time.time()
          for task_name in list(self._samples.keys()):
              self._samples[task_name] = [
                  sample for sample in self._samples[task_name]
                  if current_time - sample < self.config.retention_period
              ]
              if not self._samples[task_name]:
                  del self._samples[task_name]
          self._last_cleanup = current_time

      async def update_resource_metrics(self) -> None:
          """Update resource usage metrics."""
          if not self.config.enable_metrics:
              return

          process = psutil.Process()
          self.memory_usage.set(process.memory_info().rss)
          self.cpu_usage.set(process.cpu_percent())

      def get_performance_stats(self, task_name: str) -> Dict[str, float]:
          """Get performance statistics for task."""
          if task_name not in self._samples:
              return {}

          samples = self._samples[task_name]
          return {
              'count': len(samples),
              'mean': statistics.mean(samples),
              'median': statistics.median(samples),
              'stddev': statistics.stdev(samples) if len(samples) > 1 else 0,
              'min': min(samples),
              'max': max(samples)
          }

      @asynccontextmanager
      async def trace_operation(
          self,
          operation_name: str,
          **context: Any
      ):
          """Trace operation execution."""
          if not self.config.enable_tracing:
              yield
              return

          start_time = time.time()
          self.trace_logger.debug(
              f"Starting operation: {operation_name}",
              extra=context
          )

          try:
              yield
          finally:
              duration = time.time() - start_time
              self.trace_logger.debug(
                  f"Completed operation: {operation_name}",
                  extra={
                      **context,
                      'duration': duration
                  }
              )

      def profile_operation(
          self,
          operation_name: str
      ) -> Callable:
          """Profile operation execution."""
          if not self.config.enable_profiling:
              return lambda func: func

          def decorator(func: Callable) -> Callable:
              @functools.wraps(func)
              async def wrapper(*args: Any, **kwargs: Any) -> Any:
                  self.profiler.enable()
                  try:
                      return await func(*args, **kwargs)
                  finally:
                      self.profiler.disable()
                      stats = pstats.Stats(self.profiler)
                      stats.sort_stats('cumulative')
                      stats.print_stats()
              return wrapper
          return decorator

  class AsyncQueueMonitor:
      """Monitor async queue performance."""
      def __init__(self, queue: asyncio.Queue):
          self.queue = queue
          self._monitor_task: Optional[asyncio.Task] = None
          self._stop_event = asyncio.Event()

      async def start_monitoring(self) -> None:
          """Start queue monitoring."""
          self._monitor_task = asyncio.create_task(self._monitor_queue())

      async def stop_monitoring(self) -> None:
          """Stop queue monitoring."""
          self._stop_event.set()
          if self._monitor_task:
              await self._monitor_task

      async def _monitor_queue(self) -> None:
          """Monitor queue metrics."""
          while not self._stop_event.is_set():
              queue_size = self.queue.qsize()
              prom.queue_size.labels(queue_name='default').set(queue_size)
              await asyncio.sleep(1.0)

