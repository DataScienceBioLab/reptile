              self._resources[resource_id] = resource
              self._resource_usage[resource_id] = datetime.utcnow()
              return resource
          except Exception as e:
              logging.error(f"Resource acquisition error: {e}")
              raise

      async def release_resource(self, resource_id: str) -> None:
          """Release resource."""
          if resource_id in self._resources:
              try:
                  await self._cleanup_resource(self._resources[resource_id])
                  del self._resources[resource_id]
                  del self._resource_usage[resource_id]
              except Exception as e:
                  logging.error(f"Resource release error: {e}")

