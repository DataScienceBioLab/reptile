        self,
        message: str,
        field: str,
        value: Any,
        constraint: str
    ):
        super().__init__(
            message=message,
            code="VALIDATION_ERROR",
            details={
                "field": field,
                "value": value,
                "constraint": constraint
            }
        )

class ExternalServiceError(ApplicationError):
