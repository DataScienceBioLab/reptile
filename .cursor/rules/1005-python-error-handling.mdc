# Error handling components
@dataclass
class ErrorContext:
    """Error context information."""
    operation: str
    timestamp: datetime
    user_id: Optional[str] = None
    request_id: Optional[str] = None
    additional_info: Optional[Dict[str, Any]] = None

class ErrorLogger:
    """Structured error logging."""
    def __init__(self, logger: logging.Logger):
        self.logger = logger
        self._context: Dict[str, Any] = {}

    def with_context(self, **context: Any) -> 'ErrorLogger':
        """Add context to logger."""
        self._context.update(context)
        return self

    def log_error(
        self,
        error: Exception,
        context: Optional[ErrorContext] = None,
        level: int = logging.ERROR
    ) -> None:
        """Log error with context."""
        log_context = {
            **self._context,
            "error_type": type(error).__name__,
            "error_message": str(error),
            "stack_trace": traceback.format_exc()
        }
        
        if context:
            log_context.update({
                "operation": context.operation,
                "timestamp": context.timestamp.isoformat(),
                "user_id": context.user_id,
                "request_id": context.request_id,
                "additional_info": context.additional_info
            })
        
        if isinstance(error, ApplicationError):
            log_context.update({
                "error_code": error.code,
                "error_details": error.details
            })
        
        self.logger.log(level, "Application error", extra=log_context)

class CircuitBreaker:
    """Circuit breaker implementation."""
    def __init__(
        self,
        failure_threshold: int = 5,
        reset_timeout: float = 60.0
    ):
        self.failure_threshold = failure_threshold
        self.reset_timeout = reset_timeout
        self.failures = 0
        self.last_failure_time: Optional[float] = None
        self.state = "CLOSED"
        self._lock = asyncio.Lock()

    async def __aenter__(self) -> None:
        """Enter circuit breaker context."""
        async with self._lock:
            if self.state == "OPEN":
                if time.time() - self.last_failure_time > self.reset_timeout:
                    self.state = "HALF_OPEN"
                    self.failures = 0
                else:
                    raise ExternalServiceError(
                        service="circuit_breaker",
                        operation="check_state",
                        status_code=503,
                        response={"state": self.state}
                    )

    async def __aexit__(
        self,
        exc_type: Optional[Type[Exception]],
        exc_val: Optional[Exception],
        exc_tb: Optional[TracebackType]
    ) -> None:
        """Exit circuit breaker context."""
        async with self._lock:
            if exc_val is not None:
                self.failures += 1
                self.last_failure_time = time.time()
                if self.failures >= self.failure_threshold:
                    self.state = "OPEN"
            elif self.state == "HALF_OPEN":
                self.state = "CLOSED"
                self.failures = 0

class ResourceManager:
    """Resource lifecycle management."""
    def __init__(self):
        self._resources: Dict[str, Any] = {}
        self._cleanup_tasks: List[asyncio.Task] = []

    async def __aenter__(self) -> 'ResourceManager':
        """Enter resource manager context."""
        return self

    async def __aexit__(
        self,
        exc_type: Optional[Type[Exception]],
        exc_val: Optional[Exception],
        exc_tb: Optional[TracebackType]
    ) -> None:
        """Exit resource manager context."""
        await self.cleanup()

    async def register(
        self,
        resource_id: str,
        resource: Any,
        cleanup_func: Optional[Callable[[Any], Awaitable[None]]] = None
    ) -> None:
        """Register resource with cleanup."""
        self._resources[resource_id] = (resource, cleanup_func)

    async def cleanup(self) -> None:
        """Cleanup all resources."""
        for resource_id, (resource, cleanup_func) in self._resources.items():
            if cleanup_func:
                try:
                    await cleanup_func(resource)
                except Exception as e:
                    logging.error(f"Failed to cleanup {resource_id}: {e}")
        self._resources.clear()

# Usage example
async def process_user_request(
    user_id: str,
    request_data: Dict[str, Any]
) -> Dict[str, Any]:
    """Process user request with error handling."""
    logger = ErrorLogger(logging.getLogger(__name__))
    context = ErrorContext(
        operation="process_user_request",
        timestamp=datetime.utcnow(),
        user_id=user_id,
        request_id="req_123",
        additional_info={"data": request_data}
    )

    async with ResourceManager() as resources:
        try:
            # Validate input
            if not validate_user_data(request_data):
                raise ValidationError(
                    message="Invalid user data",
                    field="user_data",
                    value=request_data,
                    constraint="required_fields"
                )

            # Process with circuit breaker
            async with CircuitBreaker() as breaker:
                result = await process_data(request_data)
                return result

        except ValidationError as e:
            logger.with_context(
                error_type="validation",
                severity="warning"
            ).log_error(e, context)
            raise

        except ExternalServiceError as e:
            logger.with_context(
                error_type="external_service",
                severity="error"
            ).log_error(e, context)
            raise

        except Exception as e:
            logger.with_context(
                error_type="unexpected",
                severity="critical"
            ).log_error(e, context)
            raise
