# Python Error Handling Standards

## Context
- When implementing error handling
- When creating custom exceptions
- When handling external service failures
- When managing resource cleanup
- When implementing retry logic
- When handling concurrent operations
- When managing state recovery
- When implementing circuit breakers
- When handling timeouts
- When managing resource limits

## Requirements

### Exception Hierarchy
- Implement proper exception hierarchy:
  ```python
  # Good: Well-structured exception hierarchy
  class ApplicationError(Exception):
      """Base exception for application errors."""
      def __init__(
          self,
          message: str,
          code: str,
          details: Optional[Dict[str, Any]] = None
      ):
          super().__init__(message)
          self.code = code
          self.details = details or {}
          self.timestamp = datetime.utcnow()

  class ValidationError(ApplicationError):
      """Raised when data validation fails."""
      def __init__(
          self,
          message: str,
          field: str,
          value: Any,
          constraint: str
      ):
          super().__init__(
              message=message,
              code="VALIDATION_ERROR",
              details={
                  "field": field,
                  "value": value,
                  "constraint": constraint
              }
          )

  class ExternalServiceError(ApplicationError):
      """Raised when external service calls fail."""
      def __init__(
          self,
          service: str,
          operation: str,
          status_code: int,
          response: Optional[Dict[str, Any]] = None
      ):
          super().__init__(
              message=f"{service} {operation} failed with status {status_code}",
              code="EXTERNAL_SERVICE_ERROR",
              details={
                  "service": service,
                  "operation": operation,
                  "status_code": status_code,
                  "response": response
              }
          )

  class ResourceError(ApplicationError):
      """Raised when resource operations fail."""
      def __init__(
          self,
          resource_type: str,
          operation: str,
          reason: str
      ):
          super().__init__(
              message=f"{resource_type} {operation} failed: {reason}",
              code="RESOURCE_ERROR",
              details={
                  "resource_type": resource_type,
                  "operation": operation,
                  "reason": reason
              }
          )
  ```

### Error Recovery Patterns
- Implement robust error recovery:
  ```python
  # Good: Error recovery with retry and fallback
  class RetryableError(ApplicationError):
      """Base class for retryable errors."""
      def __init__(
          self,
          message: str,
          max_retries: int = 3,
          backoff_factor: float = 1.0
      ):
          super().__init__(
              message=message,
              code="RETRYABLE_ERROR"
          )
          self.max_retries = max_retries
          self.backoff_factor = backoff_factor

  class CircuitBreaker:
      """Circuit breaker for external service calls."""
      def __init__(
          self,
          failure_threshold: int = 5,
          reset_timeout: float = 60.0
      ):
          self.failure_threshold = failure_threshold
          self.reset_timeout = reset_timeout
          self.failures = 0
          self.last_failure_time: Optional[float] = None
          self.state = "CLOSED"  # CLOSED, OPEN, HALF_OPEN
          self._lock = asyncio.Lock()

      async def __aenter__(self) -> None:
          """Enter circuit breaker context."""
          async with self._lock:
              if self.state == "OPEN":
                  if time.time() - self.last_failure_time > self.reset_timeout:
                      self.state = "HALF_OPEN"
                      self.failures = 0
                  else:
                      raise CircuitBreakerOpenError(
                          "Circuit breaker is open",
                          self.failure_threshold,
                          self.reset_timeout
                      )

      async def __aexit__(
          self,
          exc_type: Optional[Type[Exception]],
          exc_val: Optional[Exception],
          exc_tb: Optional[TracebackType]
      ) -> None:
          """Exit circuit breaker context."""
          async with self._lock:
              if exc_val is not None:
                  self.failures += 1
                  self.last_failure_time = time.time()
                  if self.failures >= self.failure_threshold:
                      self.state = "OPEN"
              elif self.state == "HALF_OPEN":
                  self.state = "CLOSED"
                  self.failures = 0

  async def with_retry(
      func: Callable[..., Awaitable[T]],
      *args: Any,
      max_retries: int = 3,
      backoff_factor: float = 1.0,
      **kwargs: Any
  ) -> T:
      """Execute function with exponential backoff retry."""
      last_error: Optional[Exception] = None
      for attempt in range(max_retries):
          try:
              return await func(*args, **kwargs)
          except RetryableError as e:
              last_error = e
              if attempt < max_retries - 1:
                  delay = backoff_factor * (2 ** attempt)
                  await asyncio.sleep(delay)
              continue
      raise last_error
  ```

### Resource Management
- Implement proper resource cleanup:
  ```python
  # Good: Resource management with context managers
  class ResourceManager:
      """Manages resource lifecycle with proper cleanup."""
      def __init__(self):
          self._resources: Dict[str, Any] = {}
          self._cleanup_tasks: List[asyncio.Task] = []

      async def __aenter__(self) -> 'ResourceManager':
          """Enter resource manager context."""
          return self

      async def __aexit__(
          self,
          exc_type: Optional[Type[Exception]],
          exc_val: Optional[Exception],
          exc_tb: Optional[TracebackType]
      ) -> None:
          """Exit resource manager context and cleanup."""
          await self.cleanup()

      async def register(
          self,
          resource_id: str,
          resource: Any,
          cleanup_func: Optional[Callable[[Any], Awaitable[None]]] = None
      ) -> None:
          """Register a resource with cleanup function."""
          self._resources[resource_id] = (resource, cleanup_func)

      async def cleanup(self) -> None:
          """Cleanup all registered resources."""
          for resource_id, (resource, cleanup_func) in self._resources.items():
              if cleanup_func:
                  try:
                      await cleanup_func(resource)
                  except Exception as e:
                      logger.error(
                          f"Failed to cleanup resource {resource_id}: {e}"
                      )
          self._resources.clear()

  class DatabaseConnection:
      """Database connection with proper resource management."""
      def __init__(self, connection_string: str):
          self.connection_string = connection_string
          self._connection: Optional[Any] = None
          self._pool: Optional[Any] = None

      async def connect(self) -> None:
          """Establish database connection."""
          self._pool = await create_pool(self.connection_string)
          self._connection = await self._pool.acquire()

      async def disconnect(self) -> None:
          """Close database connection."""
          if self._connection:
              await self._pool.release(self._connection)
          if self._pool:
              await self._pool.close()

      async def __aenter__(self) -> 'DatabaseConnection':
          """Enter connection context."""
          await self.connect()
          return self

      async def __aexit__(
          self,
          exc_type: Optional[Type[Exception]],
          exc_val: Optional[Exception],
          exc_tb: Optional[TracebackType]
      ) -> None:
          """Exit connection context and cleanup."""
          await self.disconnect()
  ```

### Error Logging
- Implement comprehensive error logging:
  ```python
  # Good: Structured error logging
  class ErrorLogger:
      """Structured error logging with context."""
      def __init__(self, logger: logging.Logger):
          self.logger = logger
          self._context: Dict[str, Any] = {}

      def with_context(self, **context: Any) -> 'ErrorLogger':
          """Add context to error logger."""
          self._context.update(context)
          return self

      def log_error(
          self,
          error: Exception,
          level: int = logging.ERROR,
          **extra: Any
      ) -> None:
          """Log error with context and stack trace."""
          context = {
              **self._context,
              **extra,
              "error_type": type(error).__name__,
              "error_message": str(error),
              "stack_trace": traceback.format_exc()
          }
          
          if isinstance(error, ApplicationError):
              context.update({
                  "error_code": error.code,
                  "error_details": error.details,
                  "timestamp": error.timestamp.isoformat()
              })
          
          self.logger.log(level, "Application error", extra=context)

  class ErrorHandler:
      """Centralized error handling with logging."""
      def __init__(self, logger: ErrorLogger):
          self.logger = logger
          self._handlers: Dict[Type[Exception], Callable] = {}

      def register_handler(
          self,
          error_type: Type[Exception],
          handler: Callable[[Exception], None]
      ) -> None:
          """Register error handler."""
          self._handlers[error_type] = handler

      def handle_error(self, error: Exception) -> None:
          """Handle error with registered handler."""
          self.logger.log_error(error)
          
          for error_type, handler in self._handlers.items():
              if isinstance(error, error_type):
                  handler(error)
                  break
  ```

